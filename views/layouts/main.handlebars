<!DOCTYPE html>
<html>
<head>
    <title>Meu Blog</title>
    <!-- Caminho para o arquivo bootstrap.min.css na pasta /public -->
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <!-- Estilos CSS -->
    <style>
        /* Estilos globais */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
        }

        .container {
            margin-top: 20px;
        }

        /* Estilos para a barra de navegação */
        .navbar {
            border-bottom: 3px solid #007bff;
        }

        .navbar-brand {
            font-size: 1.5rem;
        }

        .navbar-nav .nav-link {
            color: #fff;
        }

        .navbar-nav .nav-link:hover {
            color: #f8f9fa;
        }

        /* Estilos para os cards dos artigos */
        .card {
            border: 1px solid #ddd;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .card-text {
            color: #333;
            line-height: 1.6;
        }

        /* Estilos para o formulário */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            font-weight: bold;
        }

        .form-control {
            border: 1px solid #ddd;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">Meu Blog</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/artigos">Artigos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/comentario">Criar Feedback</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        {{{body}}}
    </div>

    {{> footer}}

    <!-- Caminho para o arquivo bootstrap.min.js na pasta /public -->
    <script src="/js/bootstrap.min.js"></script>
</body>
</html>
